{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Main Script",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": ["api"],
            "justMyCode": true
        },
        {
            "name": "Python: Validation",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/validate.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Flask: API Server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/api.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "FLASK_APP": "api.py",
                "FLASK_ENV": "development"
            }
        }
    ]
}
